# Self-hosted Langfuse.
# NEXTAUTH_SECRET / SALT must be any long random strings; generate with:
#   openssl rand -base64 32
LANGFUSE_NEXTAUTH_SECRET=replace-me-nextauth-secret
LANGFUSE_SALT=replace-me-salt
LANGFUSE_ENCRYPTION_KEY=replace-me-32-byte-hex

# These are created on first login through the Langfuse UI (http://localhost:3003)
# and pasted back here so api-service and execution-service can talk to /api/public/*.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
