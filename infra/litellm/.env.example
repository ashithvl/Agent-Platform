# Copy to infra/litellm/.env and fill in real provider keys.
# LITELLM_MASTER_KEY is shared with api-service via docker-compose env; keep in sync.
LITELLM_MASTER_KEY=sk-dev-master
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional — Cohere rerank for RAG profiles (SPA uses cohere/rerank-* ids; add models in config.yaml)
COHERE_API_KEY=

# Startup logs you may see (normal on ghcr.io/berriai/litellm:main-stable):
# - "prisma migrate deploy" then "post-migration sanity check" / "migration diff" / "prisma db execute"
# - Prisma "wolfi" / "debian" engine fallback — informational, safe to ignore.
# The proxy only serves /health/liveliness after that sequence finishes (can be a few minutes).
