# Set to 1 to route the SPA at the real backend (auth-service / api-service).
# Unset or "0" keeps the SPA in localStorage demo mode (useful offline).
VITE_USE_BACKEND=1

# Phase 5 migration flags - flip one at a time.
# Each flag switches the matching SPA storage module from localStorage to the
# backing api-service route (which proxies agent-service / knowledge-service).
VITE_STORAGE_AGENTS=0
VITE_STORAGE_WORKFLOWS=0
VITE_STORAGE_GUARDRAILS=0
VITE_STORAGE_KNOWLEDGE=0
VITE_STORAGE_RAG_PROFILES=0
VITE_STORAGE_CHAT=0
