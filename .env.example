# Optional: OpenAI key for LiteLLM-backed chat (set before docker compose up for real LLM calls)
OPENAI_API_KEY=

# Shared secret for service-to-service calls (must match all services)
INTERNAL_SERVICE_TOKEN=dev-internal-token

# Authentik bootstrap/admin settings
AUTHENTIK_SECRET_KEY=replace-with-a-long-random-string
AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=admin
AUTHENTIK_BOOTSTRAP_TOKEN=bootstrap-token
# Public URL used by Authentik (nginx serves it at /authentik/). Include trailing slash.
AUTHENTIK_HOST=http://localhost:8080/authentik/
AUTHENTIK_HOST_BROWSER=http://localhost:8080/authentik/

# Optional: must match the redirect URI on the Authentik OAuth provider (used only by api-service BFF token exchange; not shown in the browser).
# OIDC_REDIRECT_URI=http://localhost:8080/callback

# Optional: Langfuse Cloud (async traces from execution-service). Leave unset to skip tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
